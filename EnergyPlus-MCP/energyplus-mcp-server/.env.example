# EnergyPlus MCP server — example env vars.
# Copy to .env (gitignored) and fill in for local HTTP testing.

# EnergyPlus install path — ONLY needed for the Local variant.
# Leave commented out when running via the energyplus-mcp-dev Docker image:
# the image has EnergyPlus 26.1.0 baked in at /app/software/EnergyPlusV26-1-0/
# and config.py auto-detects it. Setting this to a host path (e.g. /Applications/...)
# inside the container will override the in-container path and crash the server.
# EPLUS_IDD_PATH=/Applications/EnergyPlus-26-1-0/Energy+.idd

# Transport — defaults to stdio (matches today's behavior).
# Set to streamable-http to expose an HTTP server.
MCP_TRANSPORT=stdio

# HTTP transport knobs (only used when MCP_TRANSPORT=streamable-http).
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Bearer-token table for HTTP transport (JSON list).
# Required when MCP_TRANSPORT=streamable-http; ignored for stdio.
# Generate tokens with: openssl rand -hex 32
MCP_TOKENS=[{"label":"local-dev","token":"replace-with-32-plus-char-random-string-here-XXXXX"}]
